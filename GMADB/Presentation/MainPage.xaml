<Page x:Class="GMADB.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============ Header / Title Bar ============ -->
        <Grid x:Name="AppTitleBar" Padding="20,10,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Logo + Text -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="GMADB"
                               Style="{StaticResource TitleLargeTextBlockStyle}"/>
                    <TextBlock Text="Minimal ADB"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="LightGray"/>
                </StackPanel>
            </StackPanel>

            <!-- Right: GitHub Link (margin avoids caption buttons) -->
            <HyperlinkButton Grid.Column="1"
                             NavigateUri="https://github.com/yadev64/GMADB"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,150,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                    <TextBlock Text="Contribute on GitHub" />
                </StackPanel>
            </HyperlinkButton>
        </Grid>

        <!-- ============ Main Content ============ -->
        <ScrollViewer Grid.Row="1" Padding="12,0,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Controls -->
                <StackPanel Width="300"
                            Padding="20"
                            Spacing="10">
                    <!-- ADB Devices -->
                    <TextBlock Text="List all devices connected via ADB"
                               Foreground="Gray"
                               TextWrapping="Wrap" />
                    <Button Content="ADB devices"
                            HorizontalAlignment="Stretch"
                            Click="AdbDevicesButton_Click" />

                    <!-- Custom Command -->
                    <TextBlock Text="Custom Command"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Margin="0,20,0,0"/>
                    <TextBlock Text="Use custom commands to get more done"
                               Foreground="Gray"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextWrapping="Wrap"/>
                    <TextBox x:Name="CustomCommandTextBox"
                             PlaceholderText="Enter custom command..." />
                    <Button Content="Run"
                            HorizontalAlignment="Stretch"
                            Click="RunCustomCommandButton_Click" />

                    <!-- ROM Selection + Flash -->
                    <TextBlock Text="Step 1: Select the Custom ROM File"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="0,20,0,0"/>
                    <TextBox x:Name="FilePathTextBox"
                             PlaceholderText="File Path"
                             IsReadOnly="True" />
                    <Button Content="Select ROM"
                            HorizontalAlignment="Stretch"
                            x:Name="SelectRomButton"
                            Click="PickZipFileButton_Click" />

                    <TextBlock Text="Step 2: Flash (Don't close the window)"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                    <Button Content="Flash"
                            HorizontalAlignment="Stretch"
                            x:Name="FlashButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="FlashButton_Click" />
                </StackPanel>

                <!-- Right: Console Output -->
                <TextBox Grid.Column="1"
                         x:Name="OutputTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         BorderThickness="0"
                         Margin="10,0,0,0"
                         Foreground="LightGreen"
                         Background="{ThemeResource SolidBackgroundFillColorBaseAltBrush}"
                         CornerRadius="{StaticResource OverlayCornerRadius}"
                         PlaceholderText="> "
                         FontFamily="Cascadia Code, Consolas">
                </TextBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
